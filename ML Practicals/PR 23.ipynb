   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Sample dataset\n",
    "data = np.array([10, 12, 14, 15, 18, 20, 22, 25, 100])\n",
    "print(\"Original Data:\", data)\n",
    "\n",
    "# Box Plot only\n",
    "plt.boxplot(data)\n",
    "plt.title(\"Box Plot\")\n",
    "plt.ylabel(\"Values\")\n",
    "\n",
    "plt.show()"
   ]
